// prisma/schema.prisma
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

model Collection {
    id      Int     @id @default(autoincrement())
    title   String?
    content String?

    /// Stores the `Image.id` used as cover for this collection.
    coverImageId Int? @map("cover")
    images Image[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Image {
    id  Int    @id @default(autoincrement())
    src String
    width  Int?
    height Int?

    collection   Collection? @relation(fields: [collectionId], references: [id])
    collectionId Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
